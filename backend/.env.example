# Server
PORT=4000
FRONTEND_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# Production (Neon / any PostgreSQL): set DATABASE_URL and leave the rest blank
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Local SQLite (default dev):
DB_PATH=data/agentrip.db

# Local PostgreSQL (optional):
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=agentrip
# DB_PASSWORD=changeme
# DB_NAME=agentrip

# ── Hedera ────────────────────────────────────────────────────────────────────
HEDERA_NETWORK=testnet
HEDERA_ACCOUNT_ID=0.0.YOUR_ACCOUNT_ID
HEDERA_PRIVATE_KEY=your_hex_encoded_private_key

# ── Smart Contract (deployed on testnet) ──────────────────────────────────────
STAKING_CONTRACT_ID=0.0.8264743

# ── HCS Topic IDs (pre-deployed on testnet) ───────────────────────────────────
# Leave blank to auto-create on first boot, or set to reuse existing topics:
HCS_TOPIC_IDENTITY=0.0.8264956
HCS_TOPIC_FEEDBACK=0.0.8264959
HCS_TOPIC_VALIDATION=0.0.8264962
